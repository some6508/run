{
  "experimental": {
    "cache_file": { "enabled": true, "path": "./cache.db", "store_fakeip": false },
    "clash_api": { "default_mode": "规则", "external_controller": "0.0.0.0:9090", "external_ui": "./ui", "external_ui_update_interval": "1d", "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip" }
  },
  "log": { "disabled": false, "level": "error", "timestamp": true },
  "inbounds": [
    { "tag": "dns-in", "type": "direct", "listen": "0.0.0.0", "listen_port": 1053 },
    { "tag": "mixed-in", "type": "mixed", "listen": "0.0.0.0", "listen_port": 7890 },
    { "tag": "tun-in", "type": "tun", "stack": "mixed", "auto_route": true, "exclude_package": [], "address": [ "172.18.0.0/30", "fdfe:dcba:9876::1/126" ], "platform": { "http_proxy": { "enabled": false, "server": "127.0.0.1", "server_port": 7890 }}}
  ],
  "dns": {
    "final": "代理解析",
    "strategy": "prefer_ipv4",
    "reverse_mapping": true,
    "servers": [
      { "tag": "本地解析", "type": "local" },
      { "tag": "域名解析", "type": "udp", "server": "114.114.114.114" },
      { "tag": "直连解析", "type": "https", "domain_resolver": "域名解析", "server": "dns.alidns.com" },
      { "tag": "代理解析", "type": "https", "domain_resolver": "域名解析", "server": "dns.google", "detour": "🚀 节点选择" },
      { "tag": "FAKEIP", "type": "fakeip", "inet4_range": "198.18.0.0/15", "inet6_range": "fc00::/18" }
    ],
    "rules": [
      { "clash_mode": "直连", "server": "直连解析" },
      { "clash_mode": "全局", "server": "FAKEIP" },
      { "rule_set": [ "adblocksingbox" ],"action": "reject"},
      { "query_type": [ "HTTPS" ], "action": "reject" },
      { "query_type": [ "A", "AAAA" ], "server": "FAKEIP", "rewrite_ttl": 1 }
    ]
  },
  "route": {
    "final": "🐟 漏网之鱼",
    "find_process": true,
    "auto_detect_interface": true,
    "default_domain_resolver": { "server": "直连解析" },
